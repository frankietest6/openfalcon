# ============================================================
# ShowPilot — docker-compose example
# ============================================================
# Copy this file to docker-compose.yml and edit to taste, then:
#
#     docker compose up -d
#
# Things you'll likely change:
#   - The host port (left side of "3100:3100") if 3100 is taken on your host
#   - Mount paths for ./showpilot-data and ./showpilot-config (use absolute
#     paths if you prefer)
#   - The image tag (use a specific version like :0.18.5 to pin, or :latest
#     for auto-updates with `docker compose pull`)
#
# Things you MUST do before first run:
#   1. Copy config.example.js to ./showpilot-config/config.js
#      (or download from https://raw.githubusercontent.com/ShowPilotFPP/ShowPilot/main/config.example.js)
#   2. Edit ./showpilot-config/config.js — change jwtSecret and showToken
#      to long random strings (`openssl rand -hex 32` works great)
# ============================================================

services:
  showpilot:
    container_name: showpilot

    # Pull a prebuilt multi-arch image from GitHub Container Registry.
    # Supports linux/amd64 (x86 mini-PCs, NUCs) and linux/arm64 (Raspberry Pi
    # 4/5, Apple Silicon). Docker auto-selects the right architecture.
    image: ghcr.io/showpilotfpp/showpilot:latest

    # Alternative: build the image from source instead of pulling.
    # Useful for developing against a local checkout, or for self-hosters who
    # prefer to build their own images. Comment out the `image:` line above
    # and uncomment this block.
    # build: .

    restart: unless-stopped

    ports:
      # Host:Container. Change the left side if 3100 is in use.
      - "3100:3100"

    volumes:
      # Database, cover art, and any persistent data
      - ./showpilot-data:/app/data

      # Config file — mount as read-only since the app doesn't write it
      - ./showpilot-config/config.js:/app/config.js:ro

    # Optional: if you're behind a reverse proxy (Nginx Proxy Manager, Traefik,
    # Caddy) on the same Docker host, add a network here so the proxy can reach
    # the container by name. Otherwise the published port above is fine.
    # networks:
    #   - proxy

# networks:
#   proxy:
#     external: true
